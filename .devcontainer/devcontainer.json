{
  "name": "GreenCard API",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "api",
  "workspaceFolder": "/app",
  "forwardPorts": [3001, 5432, 6379],
  "postCreateCommand": "npm install && npx prisma generate",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint", "Prisma.prisma"]
    }
  }
}
