    "04_gaussian_blur": { "type": "gaussian_blur", "params": { "sigma": 3.5 } },
    "05_skewed": { "type": "skewed", "params": { "rotateDeg": 4 } },
    "06_perspective": { "type": "perspective", "params": { "affine": "shear ~0.12" } },
    "07_partial_crop": { "type": "partial_crop", "params": { "cropPercent": "8/5/84/88" } },
    "08_dark": { "type": "dark", "params": { "brightness": 0.55 } },
    "09_overexposed": { "type": "overexposed", "params": { "brightness": 1.45 } },
    "10_glare": { "type": "glare", "params": { "overlay": "radial white 85%" } },
