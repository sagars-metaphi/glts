{
  "id": "china-g-type-cover-letter-delhi",
  "name": "China G Type Cover Letter - Delhi",
  "windowSize": 220,
  "body": "ON COMPANY LETTERHEAD\n\nDate: {{date}}\n\nTo: {{to}}\n\nSub: {{subjectLine}}\n\nDear Sir / Madam,\n\nSURNAME / NAME: {{surnameName}}\nDESIGNATION: {{designation}}\nNATIONALITY: {{nationality}}\nBIRTHDATE / PLACE: {{birthPlace}}\nPASSPORT NO: {{passportNumber}}\nPASSPORT ISS / EXP: {{passportIssueDate}} / {{passportExpiryDate}}\n\nPlease be advised that the above-mentioned candidate is scheduled to join the vessel at {{joinPortChina}} on {{joiningDate}}, the {{vesselName}}, {{vesselFlag}}, IMO No. {{imoNumber}}, operated by our Principal, {{principalCompany}}.\n\nWe request you to kindly grant him Chinese \"G\" Type visa with {{visaValidityMonths}} validity, {{entriesRequested}} with longest stay of {{stayDays}} enable him to join as per ship schedule.\n\nAgent details in China:\nName: {{chinaAgentName}}\nAddress: {{chinaAgentAddress}}\nContact no: {{chinaAgentContact}}\nAuthorise person name – Designation: {{authorizedPersonName}}\n\nIf the visa is being granted and he fails to join the vessel for any reason within the period for which he is admitted, our Principals mentioned above and us will be responsible for the maintenance and repatriation to India.\n\nThanking you.\n\nYours sincerely,\n{{indianCompanyName}}\nMr. {{signatoryName}}\nDesignation: {{signatoryDesignation}}\nContact no: {{signatoryContact}}\nCompany stamp: {{companyStamp}}",
  "sections": {
    "to": {
      "start": "To\\s*[,，]?",
      "end": "Sub\\s*[:：]"
    },
    "body": {
      "start": "Please\\s+be\\s+advised",
      "end": "Agent\\s+details\\s+in\\s+China"
    },
    "candidateDetails": {
      "start": "Dear\\s+Sir",
      "end": "Please\\s+be\\s+advised"
    },
    "agentDetails": {
      "start": "Agent\\s+details\\s+in\\s+China",
      "end": "Authori[sz]e\\s+person\\s+name"
    },
    "from": {
      "start": "Yours\\s+sincerely",
      "end": null
    }
  },
  "required": [
    "date",
    "surnameName",
    "designation",
    "nationality",
    "passportNumber",
    "passportIssueDate",
    "passportExpiryDate",
    "joinPortChina",
    "vesselName",
    "imoNumber",
    "visaType",
    "entriesRequested",
    "stayDays",
    "chinaAgentName",
    "authorizedPersonName"
  ],
  "fields": {
    "date": {
      "label": "Date :",
      "aliases": ["Date:", "DATED"],
      "valuePattern": "\\d{4}[\\/\\-]\\d{2}[\\/\\-]\\d{2}",
      "required": true
    },
    "to": {
      "label": "To",
      "aliases": ["The visa officer", "Embassy of"],
      "section": "to"
    },
    "subjectLine": {
      "label": "Sub",
      "aliases": ["Sub:", "Visa Application For"],
      "valuePattern": "Visa Application[^\\n]+"
    },
    "surnameName": {
      "label": "SURNAME / NAME",
      "aliases": ["Surname / Name", "NAME"],
      "section": "candidateDetails",
      "required": true
    },
    "designation": {
      "label": "DESIGNATION",
      "aliases": ["Designation"],
      "section": "candidateDetails",
      "required": true
    },
    "nationality": {
      "label": "NATIONALITY",
      "aliases": ["Nationality"],
      "section": "candidateDetails",
      "required": true
    },
    "birthDate": {
      "label": "BIRTHDATE / PLACE",
      "aliases": ["Birthdate / Place", "Date of Birth"],
      "valuePattern": "\\d{1,2}\\s+[A-Z]+\\s+\\d{4}|\\d{4}[\\/\\-]\\d{2}[\\/\\-]\\d{2}",
      "section": "candidateDetails"
